{
  "name": "gea",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:gea": "npm run build -w @geajs/core",
    "build:gea-mobile": "npm run build -w @geajs/mobile",
    "build:vite-plugin": "npm run build -w @geajs/vite-plugin",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "format:check": "prettier --check .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "npm run build:docs -w @geajs/ui && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "example:dashboard": "vite dev examples/dashboard",
    "example:docs": "vite dev examples/docs",
    "example:forms": "vite dev examples/forms",
    "example:showcase": "vite dev examples/showcase",
    "example:saas-dashboard": "vite dev examples/saas-dashboard",
    "example:ecommerce": "vite dev examples/ecommerce",
    "example:chat": "vite dev examples/chat",
    "example:music-player": "vite dev examples/music-player",
    "example:finance": "vite dev examples/finance",
    "example:email-client": "vite dev examples/email-client",
    "example:flight-checkin": "vite dev --config examples/flight-checkin/vite.config.ts",
    "example:jira-clone": "vite dev examples/jira_clone",
    "example:kanban": "vite dev --config examples/kanban/vite.config.ts",
    "example:mobile-showcase": "vite dev --config examples/mobile-showcase/vite.config.ts",
    "example:router-simple": "vite dev examples/router-simple",
    "example:router-v2": "vite dev examples/router-v2",
    "example:todo": "vite dev examples/todo",
    "test:e2e": "npx playwright test --config=tests/e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0",
    "vitepress": "^1.6.4"
  }
}
