{
  "name": "@geajs/ssr",
  "version": "1.0.2",
  "type": "module",
  "description": "Server-side rendering for Gea framework",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/node.ts src/client.ts src/vite.ts --format esm --dts --clean",
    "test": "tsx --conditions source --test tests/**/*.test.ts"
  },
  "peerDependencies": {
    "@geajs/core": "*",
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.0"
  },
  "author": "Armagan Amcalar <armagan@amcalar.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "devalue": "^5.6.4"
  }
}
