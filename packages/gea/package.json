{
  "name": "@geajs/core",
  "type": "module",
  "version": "1.0.8",
  "description": "A lightweight, reactive JavaScript UI framework with compile-time JSX and proxy-based stores",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "tsconfig.json"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dashersw/gea.git"
  },
  "keywords": [
    "ui-framework",
    "javascript",
    "typescript",
    "jsx",
    "reactive",
    "proxy",
    "no-vdom",
    "lightweight",
    "mobile"
  ],
  "scripts": {
    "build": "tsdown --config-loader unrun && node scripts/append-jsx-types.mjs",
    "prepublishOnly": "npm run build",
    "size": "node -e \"process.stdout.write('gzip size: ')\" && gzip-size dist/gea.js",
    "ts-type-check": "tsc --noEmit --project tsconfig.build.json",
    "lint": "eslint src",
    "test": "tsx --conditions source --import ./tests/preload.ts --test tests/*.test.ts --test tests/examples/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov tsx --conditions source --import ./tests/preload.ts --test tests/*.test.ts --test tests/examples/*.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Armagan Amcalar <armagan@amcalar.com>",
  "license": "MIT",
  "sideEffects": false,
  "bugs": {
    "url": "https://github.com/dashersw/gea/issues"
  },
  "homepage": "https://github.com/dashersw/gea#readme",
  "dependencies": {
    "@types/react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "jsdom": "^29.0.0",
    "quill": "^2.0.3",
    "tsdown": "^0.21.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.0"
  }
}
