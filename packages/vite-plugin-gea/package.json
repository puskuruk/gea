{
  "name": "@geajs/vite-plugin",
  "version": "1.0.0",
  "description": "Vite plugin for Gea framework - JSX/TSX transform, reactivity, HMR",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "author": "Armagan Amcalar <armagan@amcalar.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dashersw/gea.git"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "gea",
    "jsx",
    "tsx",
    "reactivity",
    "hmr",
    "transform",
    "compile-time"
  ],
  "bugs": {
    "url": "https://github.com/dashersw/gea/issues"
  },
  "homepage": "https://github.com/dashersw/gea#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "gea-env.d.ts"
  ],
  "scripts": {
    "build": "tsup index.ts --format esm --dts --clean --external vite",
    "test": "tsx --test tests/**/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@babel/generator": "^7.23.0",
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "eszter": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "c8": "^11.0.0",
    "cssstyle": "^6.2.0",
    "jsdom": "^28.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  }
}
