{
  "extends": "../shared/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@geajs/core": [
        "../../packages/gea/src"
      ],
      "@geajs/ui": [
        "../../packages/gea-ui/src"
      ],
      "@geajs/mobile": [
        "../../packages/gea-mobile/src"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "vite.config.ts",
    "../../packages/vite-plugin-gea/gea-env.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
